{
  "name": "remote-claude",
  "version": "0.1.0",
  "description": "Local-first dev tool: push your project to a remote Mac Mini, run Claude Code there, and pull back a reviewable unified diff.",
  "type": "module",
  "license": "MIT",
  "author": "Mohamed Rebin K",
  "homepage": "https://github.com/rebink/remote_claude#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rebink/remote_claude.git"
  },
  "bugs": {
    "url": "https://github.com/rebink/remote_claude/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "ai",
    "cli",
    "remote",
    "rsync",
    "diff",
    "patch",
    "developer-tools",
    "flutter",
    "dart",
    "mac-mini"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "remote-claude": "./dist/cli.js",
    "remote-claude-agent": "./dist/agent.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev:cli": "tsx src/cli.ts",
    "dev:agent": "tsx src/agent.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepare": "[ -f tsup.config.ts ] && tsup || echo 'no source — skipping build'",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fastify": "^4.28.1",
    "prompts": "^2.4.2",
    "undici": "^6.19.8",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.2.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.4"
  }
}
