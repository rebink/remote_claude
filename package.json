{
  "name": "devbridge",
  "version": "0.1.0",
  "description": "Local-first dev tool: push project to remote Mac Mini, run Claude Code there, return a reviewable unified diff.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "devbridge": "./dist/cli.js",
    "devbridge-agent": "./dist/agent.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev:cli": "tsx src/cli.ts",
    "dev:agent": "tsx src/agent.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fastify": "^4.28.1",
    "prompts": "^2.4.2",
    "undici": "^6.19.8",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.2.4",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.4"
  }
}
